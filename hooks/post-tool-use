#!/usr/bin/env bash
set -u
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ ! -d ".ctx" ] || ! command -v node >/dev/null 2>&1; then
    cat > /dev/null 2>&1 || true
    echo '{}'
    exit 0
fi

node "$PLUGIN_ROOT/bin/ctx.js" hook-update 2>/dev/null || echo '{}'
exit 0
