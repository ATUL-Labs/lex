#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SKILL_FILE="$PLUGIN_ROOT/skills/using-ctx/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
    echo '{}'
    exit 0
fi

CONTENT="$(cat "$SKILL_FILE")"

STATE=""
if [ -f ".ctx/status.md" ]; then
    STATE="$STATE

## CURRENT PROJECT STATE (.ctx/status.md)
$(head -n 40 ".ctx/status.md")"
fi
if [ -f ".ctx/wip.md" ]; then
    STATE="$STATE

## INTERRUPTED WORK - RESUME THIS (.ctx/wip.md)
$(head -n 150 ".ctx/wip.md")"
fi

WRAPPED="<EXTREMELY_IMPORTANT>
You have ctx - the universal coding companion.

Below is the full content of your 'using-ctx' skill - your bootstrap for all skills. For all other skills, use the Skill tool:

---
$CONTENT
$STATE
</EXTREMELY_IMPORTANT>"

ESCAPED="$(printf '%s' "$WRAPPED" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null \
  || printf '%s' "$WRAPPED" | node -e 'let d="";process.stdin.on("data",c=>d+=c).on("end",()=>console.log(JSON.stringify(d)))' 2>/dev/null \
  || printf '"ctx bootstrap could not be JSON-escaped: python3 and node are both unavailable. Read the skill manually via the Skill tool."')"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{"additional_context": %s}' "$ESCAPED"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":%s}}' "$ESCAPED"
else
    printf '{"additionalContext": %s}' "$ESCAPED"
fi
